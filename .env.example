# ============================================
# Kakeru 環境変数サンプル
# .env.local にコピーして使用してください
# ============================================

# --- LLM プロバイダ ---
# provider: openai | anthropic | ollama | lmstudio
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
# 参考写真の解析に使う画像認識(vision)モデル（Ollama等）
VISION_MODEL=qwen2.5vl:7b

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Ollama (ローカルLLM / プライベートモード)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# LM Studio (OpenAI互換)
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1

# --- 画像生成 ---
# provider: replicate | fal | local_sd | none
IMAGE_PROVIDER=none
REPLICATE_API_TOKEN=
FAL_API_KEY=
LOCAL_SD_BASE_URL=http://127.0.0.1:7860

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- アプリ設定 ---
NEXT_PUBLIC_APP_NAME=Kakeru
# 日本語トークンコスト可視化を有効化
ENABLE_TOKEN_COST_DISPLAY=true
